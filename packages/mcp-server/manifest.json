{
  "dxt_version": "0.2",
  "name": "poc-dam-status-api-mcp",
  "version": "0.0.4",
  "description": "The official MCP Server for the Dam Status API API",
  "author": {
    "name": "Dam Status API"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanbinliu3379/dam-status-api-typescript.git"
  },
  "homepage": "https://github.com/yanbinliu3379/dam-status-api-typescript/tree/main/packages/mcp-server#readme",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "DAM_STATUS_API_API_KEY": "${user_config.DAM_STATUS_API_API_KEY}",
        "DAM_STATUS_API_SC_DAM": "${user_config.DAM_STATUS_API_SC_DAM}"
      }
    }
  },
  "user_config": {
    "DAM_STATUS_API_API_KEY": {
      "title": "api_key",
      "description": "",
      "required": true,
      "type": "string"
    },
    "DAM_STATUS_API_SC_DAM": {
      "title": "sc-dam",
      "description": "Base URL for the DAM service",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
